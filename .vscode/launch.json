{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "results_folder",
            "type": "promptString",
            "description": "Output folder path",
            "default": "results/"
        }
    ],
    "configurations": [
        {
            "name": "Evaluate",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/evaluate.py",
            "args": [
                "--hf_dataset", "ServiceNow-AI/EnterpriseOps-Gym",
                "--domain", "teams",
                "--mode", "oracle",
                "--llm_config", "conf/llm/gpt-5.json",
                "--output_folder", "${input:results_folder}",
                "--orchestrator", "react",
                "--concurrency", "4",
                "--num_runs", "1"
            ],
            "env": {
                "MCP_NAME_2": "knowledge-tool-mcp",
                "MCP_ENDPOINT_2": "http://127.0.0.1:8765",
                "SYSTEM_PROMPT_SUFFIX_FILE": "${workspaceFolder}/system_prompt_knowledge_suffix.txt"
            },
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Extract Trajectories",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/extract_trajectories.py",
            "args": [
                "--results-dir", "results",
                "--trajectories-dir", "trajectories"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Compute Score (teams)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/compute_score.py",
            "args": [
                "--results_folder",
                "${input:results_folder}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Scan Results",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scan_results.py",
            "args": [
                "${input:results_folder}",
                "-o", "report.csv"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
